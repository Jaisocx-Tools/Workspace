setArrowSize(size) {
  if (size !== null) {
    this.mainHtmlNode.style.setProperty('--tooltip-arrow-size', `${size}px`);
  } else {
    // Clear inline variable to fall back to theme default
    this.mainHtmlNode.style.removeProperty('--tooltip-arrow-size');
  }
}



